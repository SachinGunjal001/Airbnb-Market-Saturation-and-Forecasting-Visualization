      <column caption='indexx' datatype='integer' name='[Calculation_2269814252983771136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='rank' datatype='integer' name='[Calculation_2269814252986322946]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([price]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank Selector' datatype='string' name='[Calculation_2269814252996689927]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK_DENSE(SUM([price])) &lt;= [Parameters].[Parameter 1] THEN &quot;Show&quot;&#13;&#10;ELSE &quot;Hide&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='integer' name='[Price (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='2' formula='[price]' peg='0' size='326' />
      </column>
